  "panels": [
    {
      "id": 1,
      "title": "QPS by proto + rcode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (proto, rcode) (rate(nebula_dns_queries_total[1m]))",
          "legendFormat": "{{proto}} {{rcode}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "Query latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(nebula_dns_query_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(nebula_dns_query_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(nebula_dns_query_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "title": "Response codes",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum by (rcode) (rate(nebula_dns_queries_total[5m]))", "legendFormat": "{{rcode}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Dropped queries (by reason)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (reason) (rate(nebula_dns_dropped_total[1m]))", "legendFormat": "{{reason}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
